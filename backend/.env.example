# Application
APP_NAME=Academic RAG Assistant
APP_ENV=development
DEBUG=True
HOST=0.0.0.0
PORT=8000

# Local PostgreSQL
# Database from your screenshot: Academic-rag (owner: postgres)
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/Academic-rag

# JWT
SECRET_KEY=change-this-secret-key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# LLM Providers
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4-turbo-preview
EMBEDDING_MODEL=text-embedding-3-small
PERPLEXITY_API_KEY=
PERPLEXITY_MODEL=sonar
PERPLEXITY_BASE_URL=https://api.perplexity.ai
MISTRAL_API_KEY=
MISTRAL_MODEL=mistral-medium

# Vector Store
FAISS_INDEX_PATH=./vectorstore/faiss_index
VECTOR_DIMENSION=1536

# File Upload
MAX_UPLOAD_SIZE=10485760
ALLOWED_EXTENSIONS=pdf,docx,xlsx,pptx
UPLOAD_FOLDER=./uploads

# RAG Configuration
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
TOP_K_RESULTS=5
TEMPERATURE=0.7

# OBE
PASSING_THRESHOLD=40
CO_ATTAINMENT_THRESHOLD=50

# CORS
CORS_ORIGINS=http://localhost:3000

# Logging
LOG_LEVEL=INFO
LOG_FILE=./logs/app.log
